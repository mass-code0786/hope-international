PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mlm_db
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REMEMBER_ME_EXPIRES_IN=30d
WEBAUTHN_RP_NAME=Hope International
# WEBAUTHN_RP_ID=your-domain.com
# WEBAUTHN_ORIGIN=https://your-domain.com
#
# Required in production only when your platform does not auto-provide a mounted volume path.
# Railway: if a volume is attached, the app auto-uses RAILWAY_VOLUME_MOUNT_PATH and no MEDIA_STORAGE_ROOT is required.
# Example Render path when a persistent disk is mounted at /var/data:
# MEDIA_STORAGE_ROOT=/var/data/hope-international/media
# Example generic Linux path:
# MEDIA_STORAGE_ROOT=/var/lib/hope-international/media
# Example Windows path: D:\hope-international-media
# Optional: change the public mount path if needed. Defaults to /media.
# MEDIA_PUBLIC_PATH=/media
# Optional: set when media is served from a separate public domain/CDN.
# MEDIA_PUBLIC_BASE_URL=https://assets.your-domain.com/media
# DEV ONLY: required to run npm run reset:dev / reseed:dev
# DEV_DB_RESET_CONFIRM=RESET_HOPE_DEV_DB
